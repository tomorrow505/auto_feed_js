{
  "name": "auto-feed-refactor",
  "private": true,
  "author": "tomorrow505, gawain",
  "version": "4.0.2",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-full.js --watch",
    "dev:full": "node scripts/dev-full.js --watch",
    "dev:screen": "bash scripts/dev-full-screen.sh start",
    "dev:screen:stop": "bash scripts/dev-full-screen.sh stop",
    "dev:screen:attach": "bash scripts/dev-full-screen.sh attach",
    "dev:screen:status": "bash scripts/dev-full-screen.sh status",
    "dev:loader": "node scripts/vite.mjs",
    "build": "tsc && node scripts/vite.mjs build && node -e \"const fs=require('fs');fs.copyFileSync('dist/auto_feed.user.js','dist/auto-feed-refactor.user.js');\"",
    "preview": "node scripts/vite.mjs preview"
  },
  "dependencies": {
    "preact": "^10.0.0",
    "jquery": "^3.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "2.9.0",
    "typescript": "^5.0.0",
    "vite": "4.5.3",
    "vite-plugin-monkey": "^3.0.0",
    "@types/jquery": "^3.0.0",
    "@types/greasemonkey": "^4.0.0",
    "@types/node": "^20.0.0"
  }
}
